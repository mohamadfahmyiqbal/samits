# --- Konfigurasi Sertifikat SSL/TLS untuk Development ---

# Kunci privat (dari file server.key)
SSL_KEY_FILE=cert/pik1com074/private.key 

# Sertifikat server (dari file server.crt)
SSL_CRT_FILE=cert/pik1com074/certificate.cer

# Catatan: Beberapa server development mungkin tidak secara eksplisit 
# memerlukan file ca-chain.crt, namun disarankan untuk menginstal 
# sertifikat webserver-PIK1SVR001 (CA Anda) [cite: 1, 5] ke dalam 
# 'trusted root store' sistem operasi Anda agar browser tidak menampilkan peringatan.

# --- Konfigurasi Aplikasi (Harus diawali dengan REACT_APP_ pada CRA) ---

# Aktifkan HTTPS
HTTPS=true

# Nama Host/Domain yang disertifikasi 
# HARUS menggunakan FQDN (Fully Qualified Domain Name) dari sertifikat
REACT_APP_DOMAIN_NAME=pik1com074.local.ikoito.co.id

# Port default
PORT=3000

# Base URL backend API
REACT_APP_API_BASE_URL=https://pik1com074.local.ikoito.co.id:5002/api

# Disable source maps to fix node_modules ENOENT errors (floating-ui issue)
GENERATE_SOURCEMAP=false
