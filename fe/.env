# --- Konfigurasi Aplikasi untuk Development ---

# Gunakan HTTPS dengan certificate localhost
HTTPS=true

# SSL Certificate untuk localhost
SSL_CRT_FILE=cert/localhost/localhost.crt
SSL_KEY_FILE=cert/localhost/localhost.key

# Port default
PORT=3000

# Base URL backend API
REACT_APP_API_BASE_URL=https://localhost:5002/api

# Disable ESLint errors in development
ESLINT_NO_DEV_ERRORS=true

# Disable source maps untuk production
GENERATE_SOURCEMAP=false

# Performance settings
FAST_REFRESH=true

# Fix webpack dev server issues (safer options)
CHOKIDAR_USEPOLLING=true

# Development-only settings
GENERATE_SOURCEMAP=false
