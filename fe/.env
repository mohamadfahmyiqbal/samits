# --- Konfigurasi Aplikasi untuk Development ---

# Gunakan HTTPS dengan certificate khusus
HTTPS=true

# SSL Certificate untuk pik1com074.local.ikoito.co.id
SSL_CRT_FILE=cert/pik1com074.local.ikoito.co.id/certificate.cer
SSL_KEY_FILE=cert/pik1com074.local.ikoito.co.id/private.key

# Port default
PORT=3000

# Base URL backend API
REACT_APP_API_BASE_URL=https://pik1com074.local.ikoito.co.id:5002/api

# Disable ESLint errors in development
ESLINT_NO_DEV_ERRORS=true

# Disable source maps untuk production
GENERATE_SOURCEMAP=false

# Performance settings
FAST_REFRESH=true

# Fix webpack dev server issues (safer options)
CHOKIDAR_USEPOLLING=true

# Development-only settings
GENERATE_SOURCEMAP=false
