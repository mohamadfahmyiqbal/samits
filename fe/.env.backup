# --- Konfigurasi Aplikasi untuk Development ---

# Gunakan HTTPS dengan certificate localhost
HTTPS=true

# SSL Certificate untuk localhost
SSL_CRT_FILE=cert/localhost/localhost.crt
SSL_KEY_FILE=cert/localhost/localhost.key

# Port default
PORT=3000

# Base URL backend API
REACT_APP_API_BASE_URL=http://localhost:5002/api

# Disable source maps untuk menghindari errors
GENERATE_SOURCEMAP=false

# Performance settings
FAST_REFRESH=true
DISABLE_ESLINT_PLUGIN=true

# Fix webpack dev server issues
SKIP_PREFLIGHT_CHECK=true
CHOKIDAR_USEPOLLING=true

# Fix untuk webpack dev server terbaru
DANGEROUSLY_DISABLE_HOST_CHECK=true
TSC_COMPILE_ON_ERROR=true
